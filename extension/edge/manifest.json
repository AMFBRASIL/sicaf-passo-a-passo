{
  "manifest_version": 3,
  "name": "CadBrasil — Assistente SICAF",
  "version": "1.0.3",
  "description": "Assistente inteligente para cadastro SICAF. Abre o portal SICAF Gov.br e fornece chat IA para auxiliar no credenciamento.",
  "permissions": [
    "tabs",
    "activeTab",
    "sidePanel",
    "storage",
    "downloads",
    "scripting",
    "webRequest"
  ],
  "host_permissions": [
    "https://www3.comprasnet.gov.br/*",
    "https://*.comprasnet.gov.br/*",
    "https://acesso.gov.br/*",
    "https://*.acesso.gov.br/*",
    "https://*.cadbrasil.com.br/*",
    "https://fornecedor.cadbrasil.com.br/*",
    "https://homolog.cadbrasil.com.br/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "externally_connectable": {
    "matches": [
      "https://*.cadbrasil.com.br/*",
      "https://fornecedor.cadbrasil.com.br/*",
      "https://homolog.cadbrasil.com.br/*",
      "http://localhost/*",
      "http://127.0.0.1/*"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www3.comprasnet.gov.br/*",
        "https://*.comprasnet.gov.br/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*",
        "https://*.cadbrasil.com.br/*",
        "https://fornecedor.cadbrasil.com.br/*",
        "https://homolog.cadbrasil.com.br/*"
      ],
      "js": [
        "cadbrasil-detect.js"
      ],
      "run_at": "document_start"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "CadBrasil SICAF — Clique para abrir o assistente",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "pageworld.js"
      ],
      "matches": [
        "https://www3.comprasnet.gov.br/*",
        "https://*.comprasnet.gov.br/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
