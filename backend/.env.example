# ==============================================================================
# CADBRASIL BACKEND v2 — Variáveis de Ambiente
# ==============================================================================

# ── Aplicação ─────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173
# Vercel (backend): URL exata do frontend
# FRONTEND_URL=https://cadbrasil-fornecedor-front.vercel.app
# CORS_ALLOWED_ORIGINS=https://cadbrasil-fornecedor-front.vercel.app,https://homolog.cadbrasil.com.br
# CORS_ALLOW_VERCEL_PREVIEWS=true
TZ=America/Sao_Paulo

# ── Segurança ─────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=7d
CRON_SECRET=change_me_cron_secret_for_vercel_or_external_scheduler

# ── Cron — Google Ads Conversões (offline) ────────────────────────────────────
CRON_GOOGLE_ADS_CONVERSOES_ENABLED=true
CRON_GOOGLE_ADS_CONVERSOES_SCHEDULE=08:00,18:00
CRON_GOOGLE_ADS_CONVERSOES_RUN_AT_STARTUP=false

# ── Banco LEGADO (v1) — somente LEITURA ───────────────────────────────────────
DB_LEGACY_HOST=127.0.0.1
DB_LEGACY_PORT=3306
DB_LEGACY_USER=cadbrasilsys
DB_LEGACY_PASSWORD=
DB_LEGACY_NAME=cadbrasilsys
DB_LEGACY_POOL_MIN=1
DB_LEGACY_POOL_MAX=5

# ── Banco NOVO (v2) — LEITURA e ESCRITA ───────────────────────────────────────
# Na Vercel: cadastre TODAS estas variáveis em Settings → Environment Variables.
# Não use 127.0.0.1 — use o IP/host público do MySQL (ex.: VPS).
DB_WRITE_HOST=127.0.0.1
DB_WRITE_PORT=3306
DB_WRITE_USER=cadbrasilv2
DB_WRITE_PASSWORD=
DB_WRITE_NAME=cadbrasilv2
DB_WRITE_POOL_MIN=1
DB_WRITE_POOL_MAX=10

# Nome usado nos scripts SQL (substitui cadbrasilsys_v2 do repositório)
DB_V2_SCHEMA_NAME=cadbrasilv2

# ── E-mail (SMTP / API) ───────────────────────────────────────────────────────
# Fallback quando configuracoes_sistema (painel admin) estiver vazio.
SMTP_METODO=api
SMTP_PROVIDER=mailgun
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_TLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=CADBRASIL
SMTP_FROM_EMAIL=noreply@cadbrasil.com.br
# Mailgun / Sendgrid / Resend (método API)
MAILGUN_API_KEY=
SMTP_API_KEY=

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads
STORAGE_MAX_FILE_SIZE_MB=10

# ── Gerencianet / Efí Pay (boleto e PIX) ─────────────────────────────────────
# Obrigatório para gerar boleto/PIX. Credenciais em: https://app.sejaefi.com.br
# GERENCIANET_SANDBOX=false
# GERENCIANET_CLIENT_ID=
# GERENCIANET_CLIENT_SECRET=
# Caminho do .p12 (local/VPS) OU base64 (Vercel/serverless):
# GERENCIANET_CERTIFICATE_PATH=certs/seu-certificado.p12
# GERENCIANET_CERTIFICATE_BASE64=
# GERENCIANET_CERTIFICATE_PASSPHRASE=
# GERENCIANET_PIX_KEY=pix@suaempresa.com.br

# ── Assistente SICAF (OpenAI + extensão Chrome) ───────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=600
OPENAI_TEMPERATURE=0.3
CNPJ_CONSULTA_API_KEY=
CDP_PORT=9222
ASSISTANT_PORT=9333
SICAF_BASE_URL=https://www3.comprasnet.gov.br/sicaf-web/index.jsf
CERT_PFX_PATH=
CERT_PFX_PASSWORD=
