# ==============================================================================
# CADBRASIL BACKEND v2 — Variáveis de Ambiente
# ==============================================================================

# ── Aplicação ─────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173
TZ=America/Sao_Paulo

# ── Segurança ─────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=7d
CRON_SECRET=change_me_cron_secret_for_vercel_or_external_scheduler

# ── Banco LEGADO (v1) — somente LEITURA ───────────────────────────────────────
DB_LEGACY_HOST=127.0.0.1
DB_LEGACY_PORT=3306
DB_LEGACY_USER=cadbrasilsys
DB_LEGACY_PASSWORD=
DB_LEGACY_NAME=cadbrasilsys
DB_LEGACY_POOL_MIN=1
DB_LEGACY_POOL_MAX=5

# ── Banco NOVO (v2) — LEITURA e ESCRITA ───────────────────────────────────────
DB_WRITE_HOST=127.0.0.1
DB_WRITE_PORT=3306
DB_WRITE_USER=cadbrasilv2
DB_WRITE_PASSWORD=
DB_WRITE_NAME=cadbrasilv2
DB_WRITE_POOL_MIN=1
DB_WRITE_POOL_MAX=10

# Nome usado nos scripts SQL (substitui cadbrasilsys_v2 do repositório)
DB_V2_SCHEMA_NAME=cadbrasilv2

# ── E-mail (SMTP / API) ───────────────────────────────────────────────────────
# Fallback quando configuracoes_sistema (painel admin) estiver vazio.
SMTP_METODO=api
SMTP_PROVIDER=mailgun
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_TLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=CADBRASIL
SMTP_FROM_EMAIL=noreply@cadbrasil.com.br
# Mailgun / Sendgrid / Resend (método API)
MAILGUN_API_KEY=
SMTP_API_KEY=

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads
STORAGE_MAX_FILE_SIZE_MB=10

# ── Assistente SICAF (OpenAI + extensão Chrome) ───────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=600
OPENAI_TEMPERATURE=0.3
CNPJ_CONSULTA_API_KEY=
CDP_PORT=9222
ASSISTANT_PORT=9333
SICAF_BASE_URL=https://www3.comprasnet.gov.br/sicaf-web/index.jsf
CERT_PFX_PATH=
CERT_PFX_PASSWORD=
