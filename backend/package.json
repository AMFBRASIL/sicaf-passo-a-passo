{
  "name": "@cadbrasil/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3001",
    "dev:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next dev --port 3001",
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "build": "node scripts/bundle-sicaf-db.cjs && next build",
    "start": "next start --port 3001",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:schema": "tsx scripts/db/run-schema.ts",
    "db:sync-tables": "tsx scripts/db/sync-missing-tables.ts",
    "db:fix-tables": "tsx scripts/db/fix-missing-tables.ts",
    "db:migrate": "tsx scripts/db/run-migration-node.ts",
    "db:migrate:dados": "tsx scripts/db/run-migration-node.ts --dados",
    "db:truncate": "tsx scripts/db/truncate-v2-dados.ts",
    "db:full-migrate": "tsx scripts/db/run-full-migration.ts",
    "db:migrate:sql": "tsx scripts/db/run-migration.ts",
    "db:validate": "tsx scripts/db/run-validation-node.ts",
    "db:validate:sql": "tsx scripts/db/run-validation.ts",
    "db:status": "tsx scripts/db/check-status.ts",
    "db:seed-planos-sicaf": "tsx scripts/db/seed-planos-sicaf.ts",
    "db:seed-config-ia": "tsx scripts/db/seed-configuracoes-ia.ts",
    "db:seed-config-storage": "tsx scripts/db/seed-configuracoes-storage.ts",
    "sicaf": "node sicaf-agent/modules/sicaf-assistant/index.js",
    "sync:google-ads-conversoes": "node scripts/sync-google-ads-conversoes.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.988.0",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.5.0",
    "jose": "^6.0.11",
    "knex": "^3.1.0",
    "multer": "^2.0.2",
    "mysql2": "^3.14.1",
    "next": "^15.3.3",
    "node-forge": "^1.4.0",
    "nodemailer": "^6.10.1",
    "openai": "^4.67.0",
    "pdf-parse": "^1.1.1",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "puppeteer": "^23.11.1",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "sanitize-html": "^2.17.4",
    "sdk-node-apis-efi": "^1.3.1",
    "tarn": "^3.0.2",
    "esbuild": "^0.25.12",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.16.5",
    "@types/react": "19.2.17",
    "eslint": "^9.32.0",
    "eslint-config-next": "^15.3.3",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
