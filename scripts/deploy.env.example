# Copie para scripts/deploy.env no VPS e ajuste os nomes dos processos PM2.
# cp scripts/deploy.env.example scripts/deploy.env

DEPLOY_BRANCH=main
DEPLOY_PM2_USER=www
DEPLOY_PM2_FRONTEND=frontcadbrasilfornecedor
DEPLOY_PM2_BACKEND=cadbrasil-backend
DEPLOY_NODE_VERSION=22
# Caminho fixo do node no aaPanel (opcional), ex.:
# DEPLOY_NODE_BIN=/www/server/nodejs/v22.13.1/bin/node
# Rebuild mesmo sem commit novo (deploy manual):
# DEPLOY_FORCE=1

# Webhook (scripts/webhook-deploy.cjs)
# DEPLOY_WEBHOOK_SECRET=gere_uma_chave_longa_aleatoria
# DEPLOY_WEBHOOK_PORT=9090
